<script>
(function(){
'use strict';

// ═══════════════════════════════════════════════════════
// SABITLER
// ═══════════════════════════════════════════════════════
const PDF_URL    = 'https://voltevas.com/wp-content/uploads/2026/03/sarj_proje_taslak.pdf';
const DOSYA_ADI  = 'Elektrik_Proje_Raporu.pdf';
const KEY_SEMA   = 'proje_sema_v1';
const KEY_YAPI   = 'proje_yapi_v1';
const LS_AYAR    = 'rapor_ayarlar_v2';

// ── Her öğenin varsayılan ayarları ──────────────────────
// tip   : 'svg-fn' → generator fonksiyon SVG üretir | 'html-fn' → generator fonksiyon HTML üretir
// renderW: html-fn için sandbox genişliği (px)
const VARSAYILAN_OGELERI = [
  { id:'bina',       baslik:'🏢 Bina Görseli',            tip:'svg-fn',  x:20,  y:40,   scale:0.55, dpi:3, aktif:true },
  { id:'kolon',      baslik:'🏛️ Kolon Şeması',            tip:'svg-fn',  x:20,  y:340,  scale:0.45, dpi:3, aktif:true },
  { id:'pano',       baslik:'🗄️ Pano Görseli',             tip:'svg-fn',  x:20,  y:700,  scale:0.45, dpi:3, aktif:true },
  { id:'tekhat',     baslik:'🔌 Tekhat Şeması',            tip:'svg-fn',  x:20,  y:900,  scale:0.45, dpi:3, aktif:true },
  { id:'cetvel',     baslik:'📋 Yükleme Cetveli',          tip:'html-fn', renderW:1200, x:20, y:1050, scale:0.60, dpi:2, aktif:true },
  { id:'tesisatguc', baslik:'⚡ Tesisat Güç Bilgileri',    tip:'html-fn', renderW:900,  x:20, y:1280, scale:0.60, dpi:2, aktif:true },
  { id:'kofreolem',  baslik:'🔧 Kofre Ölçüm Değerleri',   tip:'html-fn', renderW:700,  x:20, y:1420, scale:0.60, dpi:2, aktif:true },
  { id:'yapiguc',    baslik:'🏗️ Yapı Güç Bilgileri',       tip:'html-fn', renderW:1200, x:20, y:1580, scale:0.60, dpi:2, aktif:true },
  { id:'gduzun',     baslik:'📉 GD Hesabı (En Uzun)',      tip:'html-fn', renderW:700,  x:20, y:1760, scale:0.65, dpi:2, aktif:true },
  { id:'gdguclu',    baslik:'📉 GD Hesabı (En Güçlü)',     tip:'html-fn', renderW:700,  x:380,y:1760, scale:0.65, dpi:2, aktif:true },
];
// ── DOM ──────────────────────────────────────────────
const btnKontrol    = document.getElementById('btn-kontrol');
const btnOnizle     = document.getElementById('btn-onizle');
const btnIndir      = document.getElementById('btn-indir');
const durumBar      = document.getElementById('durum-bar');
const pdfModal      = document.getElementById('pdfModal');
const pdfIframe     = document.getElementById('pdf-iframe');
const kapatModalEl  = document.getElementById('kapat-modal');
const btnIndirModal = document.getElementById('btn-indir-modal');
const progressWrap  = document.getElementById('progress-wrap');
const progressBar   = document.getElementById('progress-bar');
const sandbox       = document.getElementById('html-sandbox');
const ayarGrid      = document.getElementById('ayar-grid');

let kontrolGecti = false;
let pdfBlob      = null;

// ═══════════════════════════════════════════════════════
// AYAR PANELI OLUŞTURMA
// ═══════════════════════════════════════════════════════
let _ayarlar = {}; // { id: {x,y,scale,dpi,aktif} }

function yukleAyarlar() {
  try {
    const raw = localStorage.getItem(LS_AYAR);
    if (raw) return JSON.parse(raw);
  } catch(e){}
  return {};
}

function kaydetAyarlar() {
  try { localStorage.setItem(LS_AYAR, JSON.stringify(_ayarlar)); } catch(e){}
}

function getAyar(id) {
  return _ayarlar[id] || {};
}

function buildAyarPaneli() {
  const kayitli = yukleAyarlar();
  ayarGrid.innerHTML = '';

  VARSAYILAN_OGELERI.forEach(function(og) {
    const saved  = kayitli[og.id] || {};
    const cur = {
      x     : saved.x      != null ? saved.x      : og.x,
      y     : saved.y      != null ? saved.y      : og.y,
      scale : saved.scale  != null ? saved.scale  : og.scale,
      dpi   : saved.dpi    != null ? saved.dpi    : og.dpi,
      aktif : saved.aktif  != null ? saved.aktif  : og.aktif,
    };
    _ayarlar[og.id] = cur;

    const kart = document.createElement('div');
    kart.className = 'ayar-kart';
    kart.innerHTML = `
      <div class="ayar-kart-baslik">${og.baslik}</div>
      <div class="ayar-satirlar">
        <div class="ayar-grup">
          <label>Scale</label>
          <input class="ayar-input" id="ay-${og.id}-s" type="number" step="0.01" min="0.05" max="5" value="${cur.scale}">
        </div>
        <div class="ayar-grup">
          <label>X (pt)</label>
          <input class="ayar-input" id="ay-${og.id}-x" type="number" value="${cur.x}">
        </div>
        <div class="ayar-grup">
          <label>Y (pt)</label>
          <input class="ayar-input" id="ay-${og.id}-y" type="number" value="${cur.y}">
        </div>
        <div class="ayar-grup">
          <label>DPI×</label>
          <input class="ayar-input" id="ay-${og.id}-d" type="number" step="0.5" min="1" max="4" value="${cur.dpi}">
        </div>
        <button class="ayar-sifirla" onclick="sifirlaAyar('${og.id}',${og.scale},${og.x},${og.y},${og.dpi})">↺ Sıfırla</button>
      </div>
      <label class="ayar-aktif-toggle">
        <input type="checkbox" id="ay-${og.id}-aktif" ${cur.aktif ? 'checked' : ''}>
        PDF'e ekle
      </label>
    `;
    ayarGrid.appendChild(kart);

    // Her değişimde kaydet
    ['s','x','y','d'].forEach(function(alan) {
      document.getElementById(`ay-${og.id}-${alan}`).addEventListener('input', function() {
        okAyar(og.id);
      });
    });
    document.getElementById(`ay-${og.id}-aktif`).addEventListener('change', function() {
      okAyar(og.id);
    });
  });
}

function okAyar(id) {
  const s = parseFloat(document.getElementById(`ay-${id}-s`).value) || 0.5;
  const x = parseFloat(document.getElementById(`ay-${id}-x`).value) || 0;
  const y = parseFloat(document.getElementById(`ay-${id}-y`).value) || 0;
  const d = parseFloat(document.getElementById(`ay-${id}-d`).value) || 2;
  const a = document.getElementById(`ay-${id}-aktif`).checked;
  _ayarlar[id] = { scale:s, x:x, y:y, dpi:d, aktif:a };
  kaydetAyarlar();
}

window.sifirlaAyar = function(id, defS, defX, defY, defD) {
  document.getElementById(`ay-${id}-s`).value = defS;
  document.getElementById(`ay-${id}-x`).value = defX;
  document.getElementById(`ay-${id}-y`).value = defY;
  document.getElementById(`ay-${id}-d`).value = defD;
  document.getElementById(`ay-${id}-aktif`).checked = true;
  okAyar(id);
};

// ═════════════════════════════════════════���═════════════
// DURUM / İLERLEME
// ═══════════════════════════════════════════════════════
function gosterDurum(msg, tip) {
  durumBar.textContent   = msg;
  durumBar.className     = 'durum-bar ' + tip;
  durumBar.style.display = 'block';
}

function setProgress(pct_val) {
  progressWrap.style.display = 'block';
  progressBar.style.width    = Math.min(100, pct_val) + '%';
  if (pct_val >= 100) {
    setTimeout(function() { progressWrap.style.display='none'; progressBar.style.width='0%'; }, 800);
  }
}

// ═══════════════════════════════════════════════════════
// localStorage
// ═══════════════════════════════════════════════════════
function loadLS(key) {
  try { const d = localStorage.getItem(key); return d ? JSON.parse(d) : null; }
  catch(e) { return null; }
}

// ═══════════════════════════════════════════════════════
// SVG → Yüksek Kalite PNG
// Vektörel SVG'yi canvas'a çizip dataURL döner.
// dpiMul: canvas ölçeği (3 = ~300dpi eşdeğeri)
// ═══════════════════════════════════════════════════════
function svgToPng(svgString, pxW, pxH, dpiMul) {
  return new Promise(function(resolve, reject) {
    dpiMul = dpiMul || 3;
    const blob = new Blob([svgString], {type:'image/svg+xml;charset=utf-8'});
    const url  = URL.createObjectURL(blob);
    const img  = new Image();
    img.onload = function() {
      const cw = (pxW || img.naturalWidth  || 800) * dpiMul;
      const ch = (pxH || img.naturalHeight || 600) * dpiMul;
      const canvas  = document.createElement('canvas');
      canvas.width  = cw;
      canvas.height = ch;
      const c2d = canvas.getContext('2d');
      c2d.fillStyle = '#ffffff';
      c2d.fillRect(0, 0, cw, ch);
      c2d.drawImage(img, 0, 0, cw, ch);
      URL.revokeObjectURL(url);
      resolve({ dataUrl: canvas.toDataURL('image/png'), w: cw, h: ch, dpiMul: dpiMul });
    };
    img.onerror = function(e) {
      URL.revokeObjectURL(url);
      reject(new Error('SVG yüklenemedi'));
    };
    img.src = url;
  });
}

// ═══════════════════════════════════════════════════════
// HTML → Yüksek Kalite PNG (html2canvas)
// htmlStr : outerHTML string
// renderW : sandbox genişliği (layout)
// dpiMul  : html2canvas scale parametresi
// ═══════════════════════════════════════════════════════
function htmlToPng(htmlStr, renderW, dpiMul) {
  return new Promise(function(resolve, reject) {
    dpiMul  = dpiMul  || 2;
    renderW = renderW || 1200;

    sandbox.style.width      = renderW + 'px';
    sandbox.style.background = '#ffffff';
    sandbox.innerHTML = htmlStr;

    const el = sandbox.firstElementChild || sandbox;

    setTimeout(function() {
      // Gerçek boyutu ölç
      const rect = el.getBoundingClientRect();
      const realW = Math.ceil(rect.width)  || renderW;
      const realH = Math.ceil(rect.height) || 400;

      window.html2canvas(el, {
        backgroundColor : '#ffffff',
        scale           : dpiMul,
        useCORS         : true,
        allowTaint      : true,
        logging         : false,
        windowWidth     : renderW,
        width           : realW,
        height          : realH,
        scrollX         : 0,
        scrollY         : 0,
        x               : 0,
        y               : 0,
      }).then(function(canvas) {
        sandbox.innerHTML = '';
        resolve({
          dataUrl : canvas.toDataURL('image/png'),
          w       : canvas.width,
          h       : canvas.height,
          dpiMul  : dpiMul,
        });
      }).catch(function(e) {
        sandbox.innerHTML = '';
        reject(e);
      });
    }, 120);
  });
}

// ═══════════════════════════════════════════════════════
// PDF'E PNG EMBED
// pdfH    : sayfa yüksekliği (pt) — pdf-lib sol-alt origin için
// imgX, imgY_top: sol-üst köşe koordinatı (x soldan, y yukarıdan)
// imgW, imgH    : PDF üzerindeki boyut (pt)
// ═══════════════════════════════════════════════════════
async function embedPng(pdfDoc, page, pdfH, dataUrl, imgX, imgY_top, imgW, imgH) {
  const resp     = await fetch(dataUrl);
  const arrBuf   = await resp.arrayBuffer();
  const pngImage = await pdfDoc.embedPng(arrBuf);
  // pdf-lib: y = sol-altta origin → dönüştür
  const pdfY = pdfH - imgY_top - imgH;
  page.drawImage(pngImage, { x: imgX, y: pdfY, width: imgW, height: imgH });
}

// ═══════════════════════════════════════════════════════
// KONTROL ET
// ═══════════════════════════════════════════════════════
btnKontrol.addEventListener('click', function() {
  kontrolGecti = false;
  pdfBlob      = null;

  const sema = loadLS(KEY_SEMA);
  const yapi = loadLS(KEY_YAPI);
  const hatalar = [];

  if (!sema) hatalar.push('proje_sema_v1 bulunamadı — Elektrik Şeması sayfasını ziyaret edin');
  if (!yapi) hatalar.push('proje_yapi_v1 bulunamadı — Kolon Hesaplama sayfasını ziyaret edin');

  if (hatalar.length) {
    gosterDurum('❌ ' + hatalar.join(' | '), 'hata');
    btnOnizle.disabled = true; btnIndir.disabled = true;
    return;
  }

  // State alanlarının temel varlığını kontrol et
  const uyarilar = [];
  if (!yapi.floors || yapi.floors.length === 0) uyarilar.push('Bina katları');
  if (!sema.guc) uyarilar.push('Elektrik şeması güç verileri');

  kontrolGecti = true;
  btnKontrol.classList.add('ok');
  btnKontrol.textContent = '✅ Kontrol Tamam';
  btnOnizle.disabled = false;
  btnIndir.disabled  = false;

  if (uyarilar.length) {
    gosterDurum('⚠️ Şu veriler eksik/boş olabilir: ' + uyarilar.join(', '), 'info');
  } else {
    gosterDurum('✅ Tüm veriler mevcut. PDF oluşturulabilir.', 'tamam');
  }
});

// ═══════════════════════════════════════════════════════
// ANA PDF OLUŞTURMA
// ═══════════════════════════════════════════════════════
async function pdfOlustur() {
  gosterDurum('📥 Veriler okunuyor...', 'info');
  setProgress(5);

  const sema = loadLS(KEY_SEMA) || {};
  const yapi = loadLS(KEY_YAPI) || {};

  gosterDurum('📄 PDF şablonu indiriliyor...', 'info');
  setProgress(10);

  const resp = await fetch(PDF_URL, { cache: 'no-cache' });
  if (!resp.ok) throw new Error('Şablon indirilemedi: HTTP ' + resp.status);
  const templateBytes = await resp.arrayBuffer();

  const { PDFDocument } = window.PDFLib;
  const pdfDoc = await PDFDocument.load(templateBytes);
  const page   = pdfDoc.getPage(0);
  const { width: PW, height: PH } = page.getSize();
  console.log('PDF sayfa boyutu:', PW.toFixed(1), '×', PH.toFixed(1), 'pt');

  const aktifOgeler = VARSAYILAN_OGELERI.filter(function(og) {
    const ayar = _ayarlar[og.id] || {};
    return (ayar.aktif != null ? ayar.aktif : og.aktif);
  });

  const toplam = aktifOgeler.length;
  let tamamlanan = 0;

  gosterDurum('🖼️ ' + toplam + ' öğe işlenecek...', 'info');

  for (let i = 0; i < aktifOgeler.length; i++) {
    const og    = aktifOgeler[i];
    const ayar  = _ayarlar[og.id] || {};
    const scale = ayar.scale != null ? ayar.scale : og.scale;
    const posX  = ayar.x     != null ? ayar.x     : og.x;
    const posY  = ayar.y     != null ? ayar.y     : og.y;
    const dpi   = ayar.dpi   != null ? ayar.dpi   : og.dpi;

    gosterDurum('🖼️ [' + (i+1) + '/' + toplam + '] ' + og.baslik + ' işleniyor...', 'info');

    try {
      let result;

      if (og.tip === 'svg-fn') {
        let svgData;
        if (og.id === 'bina')   svgData = buildBinaRaporSvg(yapi);
        if (og.id === 'kolon')  svgData = buildKolonRaporSvg(yapi);
        if (og.id === 'pano')   svgData = buildPanoRaporSvg(yapi);
        if (og.id === 'tekhat') svgData = buildTekhatRaporSvg(sema);
        if (!svgData || !svgData.svgString) { continue; }
        result = await svgToPng(svgData.svgString, svgData.w, svgData.h, dpi);
      } else {
        let html;
        if (og.id === 'cetvel')     html = buildCetvelRaporHtml(sema);
        if (og.id === 'tesisatguc') html = buildTesisatGucRaporHtml(sema);
        if (og.id === 'kofreolem')  html = buildKofreOlcumRaporHtml(sema);
        if (og.id === 'yapiguc')    html = buildYapiGucRaporHtml(sema);
        if (og.id === 'gduzun')     html = buildGdRaporHtml(sema, 'uzun');
        if (og.id === 'gdguclu')    html = buildGdRaporHtml(sema, 'guclu');
        if (!html) { continue; }
        result = await htmlToPng(html, og.renderW, dpi);
      }

      const naturalW = result.w / result.dpiMul;
      const naturalH = result.h / result.dpiMul;
      const finalW   = naturalW * scale;
      const finalH   = naturalH * scale;

      await embedPng(pdfDoc, page, PH, result.dataUrl, posX, posY, finalW, finalH);

      console.log('✅', og.id,
        '→ x:', posX.toFixed(0), 'y:', posY.toFixed(0),
        'w:', finalW.toFixed(0), 'h:', finalH.toFixed(0),
        'dpi×:', dpi
      );
    } catch(e) {
      console.warn('⚠️', og.id, 'yerleştirilemedi:', e.message);
    }

    tamamlanan++;
    setProgress(10 + (tamamlanan / toplam) * 85);
  }

  const finalBytes = await pdfDoc.save();
  pdfBlob = new Blob([finalBytes], { type: 'application/pdf' });
  setProgress(100);
  gosterDurum('✅ PDF hazır! (' + toplam + ' öğe yerleştirildi)', 'tamam');
  return pdfBlob;
}

