btnOnizle.addEventListener('click', async function() {
  if (!kontrolGecti) return;
  btnOnizle.disabled    = true;
  btnOnizle.textContent = '⏳ Oluşturuluyor...';
  try {
    const blob = await pdfOlustur();
    const url  = URL.createObjectURL(blob);
    pdfIframe.src          = url;
    pdfModal.style.display = 'block';
  } catch(e) {
    gosterDurum('❌ Hata: ' + e.message, 'hata');
    console.error(e);
  } finally {
    btnOnizle.disabled    = false;
    btnOnizle.textContent = '🔍 PDF Önizle';
  }
});

btnIndir.addEventListener('click', async function() {
  if (!kontrolGecti) return;
  btnIndir.disabled    = true;
  btnIndir.textContent = '⏳...';
  try {
    const blob = pdfBlob || await pdfOlustur();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = DOSYA_ADI; a.click();
    URL.revokeObjectURL(url);
  } catch(e) {
    gosterDurum('❌ İndirme hatası: ' + e.message, 'hata');
    console.error(e);
  } finally {
    btnIndir.disabled    = false;
    btnIndir.textContent = '⬇️ PDF İndir';
  }
});

