<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mühendislik Raporu</title>
  <script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>
  <script src="https://unpkg.com/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:Arial,sans-serif;background:#f0f2f5;padding:20px}
    .rapor-wrap{max-width:1200px;margin:0 auto}
    .rapor-baslik{background:#005088;color:#fff;padding:18px 28px;border-radius:10px 10px 0 0;font-size:20px;font-weight:700;display:flex;align-items:center;gap:10px}
    .rapor-kart{background:#fff;border:1px solid #dde3ea;border-radius:0 0 10px 10px;padding:28px;box-shadow:0 2px 12px rgba(0,0,0,.08)}
    .btn-row{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:24px}
    .btn{padding:13px 28px;border:none;border-radius:7px;font-size:15px;font-weight:700;cursor:pointer;transition:all .25s;box-shadow:0 2px 6px rgba(0,0,0,.12)}
    .btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.18)}
    .btn:disabled{opacity:.45;cursor:not-allowed;transform:none!important}
    .btn-kontrol{background:#e67e22;color:#fff}
    .btn-kontrol.ok{background:#27ae60}
    .btn-onizle{background:#005088;color:#fff}
    .btn-indir{background:#27ae60;color:#fff}
    .durum-bar{padding:12px 18px;border-radius:7px;margin-bottom:20px;font-size:13px;font-weight:600;display:none}
    .durum-bar.info{background:#e8f4fd;color:#1565c0;border-left:4px solid #1565c0}
    .durum-bar.hata{background:#fdecea;color:#c62828;border-left:4px solid #c62828}
    .durum-bar.tamam{background:#e8f5e9;color:#2e7d32;border-left:4px solid #2e7d32}

    /* Ayar Grid */
    .ayar-baslik{font-size:15px;font-weight:700;color:#005088;border-bottom:2px solid #e0e8f0;padding-bottom:8px;margin:22px 0 14px;display:flex;align-items:center;gap:8px}
    .ayar-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px;margin-bottom:6px}
    .ayar-kart{background:#f8fafc;border:1px solid #dde3ea;border-radius:8px;padding:12px 14px}
    .ayar-kart-baslik{font-size:12px;font-weight:700;color:#333;margin-bottom:10px}
    .ayar-satirlar{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
